# ============================================================================
# DATAVERSE PRODUCTION CONFIGURATION
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
# Use PostgreSQL connection string with asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/dataverse
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# Redis for caching and task queue
REDIS_URL=redis://localhost:6379/0
REDIS_CONNECT_TIMEOUT_SECONDS=1

# ============================================================================
# CELERY & ASYNC TASKS
# ============================================================================
# Message broker for Celery task queue
CELERY_BROKER_URL=redis://localhost:6379/1
# Result backend for storing task results
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Secret key for JWT signing - CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# API KEYS & LLM CONFIGURATION
# ============================================================================
# Anthropic Claude (primary LLM - 200K context window)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI (fallback LLM)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_INTENT_MODEL=gpt-4o-mini

# Google Gemini (fallback or primary when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Mistral (budget routing / visualization)
MISTRAL_API_KEY=
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_REASONING_MODEL=mistral-large-latest

# DeepSeek (OpenAI-compatible, optional)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_INTENT_MODEL=deepseek-chat

# Local LLM via Ollama/DeepAnalyze
DEEPANALYZE_BASE_URL=http://localhost:11434
DEEPANALYZE_MODEL=deepanalyze-8b
DEEPANALYZE_FALLBACK_MODEL=phi3:mini
DEEPANALYZE_ALLOW_FALLBACK=true
INTENT_LLM_PROVIDER=auto

# ============================================================================
# FILE STORAGE
# ============================================================================
# Upload limits
MAX_UPLOAD_SIZE_MB=100

# Storage type: local (default), minio, s3
STORAGE_TYPE=local

# MinIO Configuration (if STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dataverse
MINIO_SECURE=false

# AWS S3 Configuration (if STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=dataverse-uploads

# ============================================================================
# ENVIRONMENT & LOGGING
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_JSON=false
APP_VERSION=1.0.0

# Comma-separated origins and hosts
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
SECURE_HEADERS_ENABLED=true
ENABLE_OPENAPI_DOCS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PATH_PREFIX=/api

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
APP_BASE_URL=http://localhost:8000
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

