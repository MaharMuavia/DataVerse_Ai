# ============================================================================
# DataVerse AI - Environment Configuration
# ============================================================================
# This file configures the DataVerse backend. Keep this file secure!
# NEVER commit this to version control if it contains real credentials.

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
# 
# Options:
# 1. LOCAL DEVELOPMENT (default):
#    - PostgreSQL running locally on port 5432
#    - Database: dataverse_db
#    - User: dataverse_user
#    - Password: dataverse_pass
#
# 2. NO DATABASE (optional):
#    - Comment out DATABASE_URL or leave blank
#    - System will work without persistence
#
# 3. MANAGED SERVICE (production):
#    - AWS RDS, Azure Database, Heroku Postgres, etc.
#    - Replace host, user, password, port as needed

DATABASE_URL=postgresql+asyncpg://dataverse_user:dataverse_pass@localhost:5432/dataverse_db

# ============================================================================
# OPENAI CONFIGURATION (Optional)
# ============================================================================
# If configured, enables LLM-based intent parsing for natural language queries
# If not configured, system falls back to keyword-based intent detection
# 
# Get API key from: https://platform.openai.com/api-keys

# OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================================
# DEEPANALYZE / OLLAMA CONFIGURATION (Optional)
# ============================================================================
# For local LLM reasoning (Ollama with DeepAnalyze model)

DEEPANALYZE_BASE_URL=http://localhost:11434
DEEPANALYZE_MODEL=deepanalyze-8b
DEEPANALYZE_FALLBACK_MODEL=phi3:mini
DEEPANALYZE_TIMEOUT=20
DEEPANALYZE_ALLOW_FALLBACK=true

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_DIR=./logs
MAX_UPLOAD_SIZE_MB=50
