# Backend runtime
ENVIRONMENT=production
APP_VERSION=1.0.0
ENABLE_OPENAPI_DOCS=false

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
LOG_DIR=./logs

# Security
SECRET_KEY=change-me-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=https://your-client-domain.com
TRUSTED_HOSTS=your-api-domain.com
SECURE_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PATH_PREFIX=/api

# Database and cache
DATABASE_URL=postgresql+asyncpg://dataverse:change-me@postgres:5432/dataverse
DATABASE_CONNECT_TIMEOUT_SECONDS=5
REDIS_URL=redis://redis:6379/0
REDIS_CONNECT_TIMEOUT_SECONDS=1
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Optional model providers
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_INTENT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_INTENT_MODEL=deepseek-chat
MISTRAL_API_KEY=
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_REASONING_MODEL=mistral-large-latest
TOGETHER_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
APP_BASE_URL=http://localhost:8000
